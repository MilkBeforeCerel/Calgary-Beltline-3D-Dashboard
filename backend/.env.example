# Copy to .env and fill in real values. .env is gitignored.

# Groq (or any OpenAI-compatible chat completions endpoint) API key used to
# interpret natural-language map queries. Leave blank to run the
# keyword-based fallback interpreter instead (see app/services/llm_service.py).
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant

# "live" | "auto" | "mock" -- see app/config.py
DATA_SOURCE_MODE=auto

# Defaults to sqlite:///<repo>/backend/masiv.db if unset -- see app/config.py
DATABASE_URL=
